#!/bin/bash
set -e

cd "$(dirname "$0")/.."

echo "Building Kraken.app..."
./scripts/build-app.sh

echo "Quitting old instance..."
pkill -x Kraken 2>/dev/null || true
sleep 1

echo "Installing to ~/Applications..."
rm -rf ~/Applications/Kraken.app
cp -R Kraken.app ~/Applications/

echo "Launching..."
open ~/Applications/Kraken.app
